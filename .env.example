# ─────────────────────────────────────────────
# Hybrid AI Agent — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────

# ── OpenAI ────────────────────────────────────
OPENAI_API_KEY=sk-...           # Your OpenAI API key
OPENAI_MODEL=gpt-4o             # LLM model to use
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Embedding Mode ────────────────────────────
# "local"  = free, uses sentence-transformers (all-MiniLM-L6-v2), no API cost
# "openai" = paid, uses OpenAI text-embedding-3-small, requires billing credits
EMBEDDING_MODE=local
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── SQLite Database ───────────────────────────
SQLITE_DB_PATH=data/db/company.db

# ── ChromaDB ─────────────────────────────────
CHROMA_PERSIST_DIR=data/chroma  # Folder where ChromaDB stores its data
CHROMA_COLLECTION_NAME=hr_docs  # Default collection name

# ── Router / Agent Settings ───────────────────
MAX_MEMORY_TURNS=5              # How many past turns to keep in memory
TOP_K_RETRIEVAL=5               # Number of chunks to retrieve from vector store
RERANKER_TOP_N=3                # Number of results to keep after reranking

# ── Logging ───────────────────────────────────
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
